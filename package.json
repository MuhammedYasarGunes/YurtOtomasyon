{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
  "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.mjs",
  "start": "node --env-file=.env dist/server.mjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/infrastructure/database/data-source.ts src/infrastructure/database/migrations/InitSchema",
    "migration:run": "npm run typeorm -- migration:run -d src/infrastructure/database/data-source.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mongodb": "^6.5.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.30",
    "uuid": "^9.0.1",
    "vite": "^6.2.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
