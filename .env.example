# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
API_URL=http://localhost:3000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=yurtapp_user
DB_PASSWORD=yurtapp_password
DB_DATABASE=yurtapp_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# Optional: MongoDB Configuration (for multi-DB support)
MONGODB_URI=mongodb://localhost:27017/yurtapp

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Configuration (for future auth)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=24h

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Application
APP_NAME=YurtApp
APP_VERSION=2.0.0
